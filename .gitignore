# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Generated local development credentials
.dev/

# Generated Go protobuf bindings
pkg/proto/**/*.pb.go

# env file
.env

# Editor/IDE
.idea/
*.iml
/bin/

# Local agent-planning notes and historical planning archives.
/AGENTS.md
/AGENTIC_*.md
/docs/*
!/docs/README.md
!/docs/architecture-decision-record.md
**/AGENTS.md
**/AGENTIC_*.md
