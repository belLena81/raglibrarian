# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Generated local development credentials
.dev/

# Local Docker service logs captured by scripts/run-local.sh
_logs/

# Generated Go protobuf bindings
pkg/proto/**/*.pb.go

# env file
.env

# Editor/IDE
.idea/
*.iml
/bin/

# Local Codex project settings
/.codex/config.toml

# Local agent-planning notes and historical planning archives.
/AGENTS.md
/AGENTIC_*.md
/docs/*
!/docs/README.md
!/docs/architecture-decision-record.md
!/docs/spec_rag_tech_books.md
**/AGENTS.md
**/AGENTIC_*.md
!/services/edge-api/AGENTS.md
!/services/edge-api/AGENTIC_DEVELOPMENT.md
