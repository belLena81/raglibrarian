# Copy to deploy/cloud-test/.env.cloud and replace every required placeholder.
# This file contains configuration only. Keep credentials in runtime/secrets.
SECRET_DIR=./deploy/cloud-test/runtime/secrets
CERT_DIR=./deploy/cloud-test/runtime/certs
M5_MODEL_DIR=./deploy/cloud-test/runtime/models/m5-jina-code-v1

# Tailscale Serve HTTPS URL, without a trailing slash.
PUBLIC_ORIGIN=https://raglibrarian.example-tailnet.ts.net

# Optional RabbitMQ HTTPS management API base. Leave empty for CloudAMQP,
# where it is derived from the AMQPS host as https://HOST/api.
RABBITMQ_MANAGEMENT_BASE_URL=

# S3-compatible endpoint, without a scheme or path. Cloudflare R2 EU is the
# default free option; AWS S3, DigitalOcean Spaces, or private MinIO can be used
# after the live storage contract passes.
S3_ENDPOINT=ACCOUNT_ID.eu.r2.cloudflarestorage.com
S3_ORIGINAL_BUCKET=raglibrarian-original-books
S3_ARTIFACT_BUCKET=raglibrarian-ingestion-artifacts

# Standard STARTTLS SMTP. Defaults below target Brevo; SES SMTP and other
# providers can be substituted without application changes.
SMTP_ADDR=smtp-relay.brevo.com:587
SMTP_SERVER_NAME=smtp-relay.brevo.com
SMTP_USERNAME=REPLACE_ME
SMTP_FROM=verified-sender@example.com

# OpenAI-compatible Groq endpoint. Enable Zero Data Retention before private-book tests.
ANSWER_LLM_BASE_URL=https://api.groq.com/openai
ANSWER_LLM_MODEL=openai/gpt-oss-20b

# Fixed private Compose network used to validate the immediate reverse proxy.
EDGE_TRUSTED_PROXY_CIDRS=172.30.10.0/24

# OCI A1 test-host resource settings.
IDENTITY_BCRYPT_CONCURRENCY=2
# After the administrator is created, set this to an empty value and recreate Identity.
IDENTITY_BOOTSTRAP_VERIFIER_FILE=/run/secrets/identity_bootstrap_verifier
INGESTION_CPU_LIMIT=0.75
INGESTION_MEMORY_LIMIT=1g
M5_TEI_CPU_LIMIT=1.5
M5_TEI_MEMORY_LIMIT=4g

# Native linux/arm64 image manifests verified for the cloud-test profile.
M5_QDRANT_IMAGE=qdrant/qdrant@sha256:e8c968e9a32219a4cde0d34ee594ad697ed92df41c542b5ec2d178eaa807804b
M5_TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference@sha256:7e0ad922d10ef6f728b521d1a47e83004480687bd4073c97f079c806e3e92a41
