# Paths only: generate actual local credentials with `make dev-secrets`.
# Never place DSNs, passwords, private keys, bootstrap codes, or tokens here.
SECRET_DIR=./.dev/secrets
CERT_DIR=./.dev/certs

# Loopback-only local endpoints.
EDGE_PORT=8080
MAILPIT_UI_PORT=8025

# Required only because the local Edge endpoint is plain HTTP.
EDGE_INSECURE_REFRESH_COOKIE=true

# Optional hardening. Forwarded client IP headers are ignored unless every
# direct peer address is covered by one of these comma-separated CIDRs.
EDGE_TRUSTED_PROXY_CIDRS=
IDENTITY_BCRYPT_CONCURRENCY=4

# Numeric distroless identity used after service secrets are loaded.
RUN_AS_UID=65532
RUN_AS_GID=65532
# Milestone 6 real-provider configuration. Keep the API key in the referenced
# owner-readable file; never place it in this environment file.
ANSWER_LLM_BASE_URL=
ANSWER_LLM_MODEL=
ANSWER_LLM_API_KEY_PATH=.dev/secrets/answer_llm_api_key
