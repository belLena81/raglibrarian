# Generate these values with: make keygen >> .env
IDENTITY_SIGNING_KEY=
EDGE_VERIFY_KEY=

# Local Compose-only credentials. Do not reuse outside development.
POSTGRES_USER=raglibrarian
POSTGRES_PASSWORD=raglibrarian_local
POSTGRES_DB=raglibrarian
IDENTITY_DB_PASSWORD=identity_local
CATALOG_DB_PASSWORD=catalog_local
IDENTITY_POSTGRES_DSN=postgres://identity_role:identity_local@postgres:5432/raglibrarian?sslmode=disable
CATALOG_POSTGRES_DSN=postgres://catalog_role:catalog_local@postgres:5432/raglibrarian?sslmode=disable

# The Compose stack is the supported local workflow; these paths are mounted
# inside containers by docker-compose.yml.
CERT_DIR=./.dev/certs
QUERY_ADDR=:8080
IDENTITY_GRPC_ADDR=identity-service:50051
CATALOG_GRPC_ADDR=catalog-service:50052
INTERNAL_TLS_CA_FILE=/run/secrets/internal_ca
EDGE_TLS_CERT_FILE=/run/secrets/edge_tls_cert
EDGE_TLS_KEY_FILE=/run/secrets/edge_tls_key
IDENTITY_TLS_CERT_FILE=/run/secrets/identity_tls_cert
IDENTITY_TLS_KEY_FILE=/run/secrets/identity_tls_key
CATALOG_TLS_CERT_FILE=/run/secrets/catalog_tls_cert
CATALOG_TLS_KEY_FILE=/run/secrets/catalog_tls_key

# Required only because the local Edge endpoint is plain HTTP.
EDGE_INSECURE_REFRESH_COOKIE=true
LOG_ENV=development
LOG_LEVEL=debug

# Optional hardening. Forwarded client IP headers are ignored unless every
# direct peer address is covered by one of these comma-separated CIDRs.
EDGE_TRUSTED_PROXY_CIDRS=
# Bounds expensive password work inside Identity.
IDENTITY_BCRYPT_CONCURRENCY=4
# Numeric distroless identity used after service-specific secrets are loaded.
RUN_AS_UID=65532
RUN_AS_GID=65532
